#!/bin/sh

. "$TEST_SHELL_PATH/sharded-dbops-security-upgrade/abstract-sharded-security-upgrade"

shell_unit_test() {
  EXCLUSIVE_OP=true
  printf %s ' Completed ' > "$TEST_TARGET_PATH/dbops-test-coord-status"
  printf %s ' Failed ' > "$TEST_TARGET_PATH/dbops-test-shard0-status"
  ! (shell_unit_test_sharded_dbops)
  check_sharded_dbops_result || return 1
  grep -q '^FAILURE=security upgrade failed. SGDbOps test-shard0 failed$' \
    "$SHARED_PATH/$KEBAB_OP_NAME.out"
  grep -q '^EXIT_CODE=1$' "$SHARED_PATH/$KEBAB_OP_NAME.out"
}
